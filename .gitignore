# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/

# Data (not committed — see data/README.md)
data/*
!data/README.md

# Pipeline outputs and generated figures/tables (all regenerated by the scripts)
# outputs/ is working scratch and stays ignored, EXCEPT the CSVs the paper's tables are
# generated from: without those, Tables S11, S13 and S14 do not rebuild from a clean clone,
# which the availability statement promises they do. Note the contents are excluded rather
# than the directory itself, because git does not descend into an excluded directory and a
# negation underneath one has no effect.
/outputs/*
!/outputs/trajectory/
!/outputs/gene_embedding_ablation/
/outputs/trajectory/*
!/outputs/trajectory/*.csv
# Per-dataset gene-trajectory marker orders (canonical_rank + Step (ii) scores).
# Re-include the per-dataset subdirs so git descends, exclude their contents, then
# keep only the *_orders.csv files (Tables S13/S14 and the cascade/dev-marker figures
# read outputs/trajectory/<ds>/gene_trajectory_<ds>_orders.csv).
!/outputs/trajectory/*/
/outputs/trajectory/*/*
!/outputs/trajectory/*/gene_trajectory_*_orders.csv
# GeneTrajectory full pseudoorder tables: input to score_gt_3variants.py's
# best-trajectory scoring variant. Expensive to regenerate (full OT pipeline via
# run_genetrajectory.py, needs scanpy + the gene_trajectory package), so ship as data.
!/outputs/trajectory/*/gt_full_trajectories.csv
/outputs/gene_embedding_ablation/*
!/outputs/gene_embedding_ablation/*.csv
# Ten-seed and audit inputs for the main gene-ordering table (added 2026-07-20).
# Only the CSVs the generators read live in these directories here; the probe
# scripts and internal notes that sit beside them upstream are NOT shipped.
!/outputs/gene_embedding_ablation/*/
/outputs/gene_embedding_ablation/*/*
!/outputs/gene_embedding_ablation/*/*.csv
!/outputs/trajectory/tenseed_*/
/outputs/trajectory/tenseed_*/*
!/outputs/trajectory/tenseed_*/*.csv
/figures/
/paper/

# Patched MALLET checkout (built locally — see mallet_patch/README.md)
/mallet/

# MALLET InstanceList files. Generated on first run by scripts/build_ser.py and
# reused by scripts/train_prism_standard.py, so they rebuild from data/ and are
# never shipped. The paths come from config/prism_pg_*.json ("ser_file").
/ground_truth_ser/

# LaTeX build artifacts
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.bbl
*.blg
*.synctex.gz
*.toc

# Local working notes (never part of the release)
/PREPARATION_REPORT.md

# OS / editor junk
._*
.DS_Store
Thumbs.db
*.stackdump

# Generator side-outputs (regenerated on demand)
/results/robustness_aggregates_*.csv
/results/full_metrics_o*.csv
